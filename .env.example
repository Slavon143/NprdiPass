#--------------------------------------------------------------------------
# Application
#--------------------------------------------------------------------------
APP_NAME=NordiPass
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
PASSPORT_PUBLIC_BASE_URL="${APP_URL}"
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

#--------------------------------------------------------------------------
# Logging
#--------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

BROADCAST_CONNECTION=log

#--------------------------------------------------------------------------
# Database
#--------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nordipass
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
# MYSQL_ATTR_SSL_CA=

#--------------------------------------------------------------------------
# Session
#--------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

#--------------------------------------------------------------------------
# Cache
#--------------------------------------------------------------------------
CACHE_STORE=database
# CACHE_PREFIX=

#--------------------------------------------------------------------------
# Queue
#--------------------------------------------------------------------------
QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=360
# QUEUE_WORKER_TIMEOUT=300

#--------------------------------------------------------------------------
# Redis (production recommendation)
#--------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

#--------------------------------------------------------------------------
# Mail
#--------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@nordipass.local"
MAIL_FROM_NAME="${APP_NAME}"

#--------------------------------------------------------------------------
# Filesystem
#--------------------------------------------------------------------------
FILESYSTEM_DISK=local

#--------------------------------------------------------------------------
# Tenancy
#--------------------------------------------------------------------------
TENANCY_SESSION_KEY=nordipass.current_company_id

#--------------------------------------------------------------------------
# Invitations
#--------------------------------------------------------------------------
INVITATION_EXPIRES_HOURS=72
INVITATION_RETENTION_DAYS=180
INVITATION_MAILER=array

#--------------------------------------------------------------------------
# Audit
#--------------------------------------------------------------------------
AUDIT_RETENTION_DAYS=365
AUDIT_STORE_IP=true
AUDIT_USER_AGENT_MAX_LENGTH=500

#--------------------------------------------------------------------------
# API
#--------------------------------------------------------------------------
API_DEFAULT_TOKEN_EXPIRATION_DAYS=90
API_MAX_TOKEN_EXPIRATION_DAYS=365
API_ALLOW_NON_EXPIRING_TOKENS=false
API_TOKEN_RETENTION_DAYS=30
API_PRUNE_INACTIVE_USER_TOKENS=true
API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
SANCTUM_TOKEN_PREFIX=

#--------------------------------------------------------------------------
# Security
#--------------------------------------------------------------------------
BCRYPT_ROUNDS=12
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false
TRUSTED_PROXIES=
TRUSTED_HOSTS=localhost,127.0.0.1,nordipass.test

#--------------------------------------------------------------------------
# Backup
#--------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_DISK=local
BACKUP_PATH=nordipass/backups
BACKUP_DATABASE_ENABLED=true
BACKUP_FILES_ENABLED=true
BACKUP_DATABASE_BINARY=
RESTORE_DATABASE_BINARY=
BACKUP_COMPRESSION=gzip
BACKUP_VERIFY_AFTER_CREATE=true
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3
BACKUP_LOCK_MINUTES=180
BACKUP_MAX_AGE_HOURS=24
BACKUP_ENCRYPTION_ENABLED=false

#--------------------------------------------------------------------------
# Health
#--------------------------------------------------------------------------
HEALTH_ENABLED=true
HEALTH_DETAILS=false
HEALTH_REQUIRE_DATABASE=true
HEALTH_REQUIRE_CACHE=true
HEALTH_REQUIRE_QUEUE=true
HEALTH_REQUIRE_SCHEDULER=false
HEALTH_SCHEDULER_MAX_AGE=180
HEALTH_REQUIRE_ASYNC_QUEUE=false

#--------------------------------------------------------------------------
# Rate Limits
#--------------------------------------------------------------------------
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_API_PUBLIC_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_INVITATIONS_MANAGE_PER_MINUTE=10
RATE_LIMIT_INVITATIONS_VERIFY_PER_MINUTE=20
RATE_LIMIT_INVITATIONS_ACCEPT_PER_MINUTE=10
RATE_LIMIT_TOKEN_CREATE_PER_MINUTE=10
RATE_LIMIT_TOKEN_REVOKE_PER_MINUTE=30

#--------------------------------------------------------------------------
# Vite
#--------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
